{
  "name": "apollos-table",
  "version": "1.0.0",
  "description": "Website security scanner & report generator for local businesses",
  "main": "cli.js",
  "bin": {
    "apollo": "./cli.js"
  },
  "scripts": {
    "scan": "node cli.js scan",
    "discover": "node cli.js discover",
    "report": "node cli.js report",
    "export": "node cli.js export",
    "server": "node server.js",
    "dev": "concurrently \"node server.js\" \"cd app && npm run dev\"",
    "build": "cd app && npm run build",
    "test": "jest --runInBand --forceExit"
  },
  "author": "Blake Corbit",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "node-html-parser": "^7.0.1",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.3.0"
  }
}
